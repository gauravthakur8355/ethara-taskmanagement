// ══════════════════════════════════════════════════════════════
// Ethara Task Managment — Prisma Schema
// 
// Design desicions (for anyone reading this at 3am):
//
// 1. UUIDs over auto-increment IDs — prevents enumeration atacks
//    and makes it safe to expose IDs in URLs without leaking info
//    about how many records exist in the system
//
// 2. Soft-delete pattern NOT used here (yet) — keeping it simple 
//    for v1. We can add a `deletedAt` column later if stakholders
//    ask for "undo delete" functinality
//
// 3. ProjectMember is an explicit join table instead of implicit 
//    many-to-many — because we need the `role` field on the 
//    relationship itself. Prisma's implicit m2m doesnt support
//    extra fields on the join table unfortunatly
//
// 4. Indexes on foreign keys and commonly queried feilds — 
//    PostgreSQL auto-creates indexes for primary keys but NOT
//    for foreign keys (unlike MySQL). So we add them manualy
//
// 5. Using @map and @@map to keep JS-style camelCase in code
//    but snake_case in the databse — becuase SQL conventions matter
// ══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────
// Enums — keeping these at the top so they're easy to find
// (i always have to scroll around looking for enums in large schemas)
// ─────────────────────────────────────

// global user role — determins what a user can do system-wide
// this is diffrent from ProjectRole which is per-project
enum Role {
  ADMIN
  MANAGER
  MEMBER
}

// per-project role — controls what a member can do within a specifc project
// kept seperate from the global Role becuase you might be an ADMIN globaly
// but only a MEMBER in someone elses project
enum ProjectRole {
  ADMIN
  MEMBER
}

// kanban-style task statuses — preety standard stuff
// considered adding BLOCKED but decided agianst it for v1
// (YAGNI and all that)
enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

// task prioriy — four levels should be enoguh for anyone
// (famous last words, i know)
enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─────────────────────────────────────
// Models
// ─────────────────────────────────────

/// The User model — the core of eveyrthing
/// every action in the system ties back to a user
model User {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(255)
  password  String   // hashed with bcrypt — NEVER store plaintext, obvously
  avatar    String?  @db.VarChar(500) // url to profile pic, nullable for now
  role      Role     @default(MEMBER)
  isActive  Boolean  @default(true) @map("is_active")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── Relations ──
  // projects this user created (one-to-many)
  ownedProjects   Project[]       @relation("ProjectCreator")
  // projects this user is a memebr of (through join table)
  projectMembers  ProjectMember[]
  // tasks assigned to this user
  assignedTasks   Task[]          @relation("TaskAssignee")
  // tasks this user created (for audit trail purpuses)
  createdTasks    Task[]          @relation("TaskCreator")
  // comments left by this user
  comments        Comment[]

  @@map("users")
}

/// Project — a container for tasks, basially like a Trello board
/// each project has a creator and multiple members with diffrent roles
model Project {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(200)
  description String?  @db.Text // nullable because not every project needs one
  slug        String   @unique @db.VarChar(200) // url-frindly version of the name
  isArchived  Boolean  @default(false) @map("is_archived")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // ── Relations ──
  // who created this project — cant be null
  createdById String  @map("created_by_id")
  createdBy   User    @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Cascade)

  // members of this project (through join tabel)
  members     ProjectMember[]
  // tasks that belong to this projcet
  tasks       Task[]

  // index on createdById so we can quickly find all projects by a user
  // without this, that query would be a full tabel scan — yikes
  @@index([createdById])
  @@map("projects")
}

/// ProjectMember — the join table betwen User and Project
/// this is where we store the per-project role
/// 
/// the @@unique constraint prevents a user from being added to 
/// the same project twice — ask me how i know this is importent
model ProjectMember {
  id        String      @id @default(uuid())
  role      ProjectRole @default(MEMBER)
  joinedAt  DateTime    @default(now()) @map("joined_at")

  // ── Relations ──
  userId    String @map("user_id")
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // composite unique — one membership per user per project
  // tried this without the unique constraint once... duplicates eveyrwhere
  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@map("project_members")
}

/// Task — the main work item
/// belongs to a project, assigned to a user, has status and priortiy
/// 
/// design note: assignedToId is nullable becuase tasks can be 
/// unassigned (like in a backlog). tried making it required once
/// and the product team was NOT happy about it lol
model Task {
  id          String     @id @default(uuid())
  title       String     @db.VarChar(300)
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?  @map("due_date") // nullable — not all tasks have deadlnes
  position    Int        @default(0) // for ordering within a column/status — drag and drop suport

  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // ── Relations ──
  // which project does this task blong to
  projectId   String  @map("project_id")
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // who is this task assgined to (nullable = unassigned)
  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  // who created this task — for audit trail
  createdById  String  @map("created_by_id")
  createdBy    User    @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)

  // comments on this task
  comments     Comment[]

  // indexes for the most common quieries:
  // - "show me all tasks in this project" (filtered by status)
  // - "show me all tasks asigned to me"
  // - "show me overdue tasks" (need dueDate index)
  @@index([projectId, status])
  @@index([assignedToId])
  @@index([dueDate])
  @@index([createdById])
  @@map("tasks")
}

/// Comment — because tasks need dicussion threads
/// keeping it simple for v1 — just text comments, no attachemnts yet
model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── Relations ──
  taskId    String @map("task_id")
  task      Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId  String @map("author_id")
  author    User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([authorId])
  @@map("comments")
}
